{ 
  "name": "cannonball",
  "private": true,
  "type": "module",
  "overrides": {
    "uuid": "^9.0.0"
  },
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev:client": "npm -w client run dev",
    "dev:server": "npm -w server run dev",
    "build": "npm -w client run build",
    "start": "node --import tsx server/src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "tsx": "^4.23.1"
  },
  "devDependencies": {
    "playwright": "^1.61.1",
    "typescript": "^5.9.2",
    "vitest": "^4.1.10"
  }
}
